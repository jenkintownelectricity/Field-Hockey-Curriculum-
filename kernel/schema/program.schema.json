{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FieldHockeyKernel Program",
  "type": "object",
  "required": ["id", "name", "ageGroup", "weeks", "description"],
  "properties": {
    "id": { "type": "string", "pattern": "^program_[a-z0-9_]+$" },
    "name": { "type": "string" },
    "ageGroup": { "type": "string", "enum": ["u6", "u8", "u10", "u12", "u14"] },
    "description": { "type": "string" },
    "weeks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["weekNumber", "theme", "sessions"],
        "properties": {
          "weekNumber": { "type": "integer" },
          "theme": { "type": "string" },
          "sessions": {
            "type": "array",
            "items": { "type": "string", "description": "Session ID reference" },
            "minItems": 1
          },
          "homeAssignment": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "goals": { "type": "array", "items": { "type": "string" } },
    "assessmentCriteria": { "type": "array", "items": { "type": "string" } }
  }
}
